{
  "version": "v1",
  "hooks": [
    {
      "name": "drovr-session-start",
      "trigger": "SessionStart",
      "action": {
        "type": "command",
        "command": "~/.kiro/hooks/drovr-agent-state.sh"
      }
    },
    {
      "name": "drovr-session-stop",
      "trigger": "Stop",
      "action": {
        "type": "command",
        "command": "~/.kiro/hooks/drovr-agent-state.sh"
      }
    }
  ]
}
