#!/bin/bash
# agy (Antigravity / Claude Code) wrapper for subagent spawning with auto-return
# Usage: agy-sub <return-pane-id> <prompt>
#   return-pane-id: herdr pane ID to send result back to (e.g. w3:pM)
#   prompt: the prompt to pass to agy -p

set -eu

RETURN_PANE="${1:?Usage: agy-sub <return-pane-id> <prompt>}"
shift
PROMPT="$*"

OUTPUT_FILE=$(mktemp /tmp/agy-sub-XXXXXX.txt)
trap "rm -f $OUTPUT_FILE" EXIT

# Report working status
if command -v drovr &>/dev/null; then
  drovr agent report working --message "Running agy" 2>/dev/null || true
fi

# Run agy in print mode (non-interactive), tee for pane display
agy --dangerously-skip-permissions -p "$PROMPT" 2>&1 | tee "$OUTPUT_FILE"

# Strip ANSI escape codes
CLEAN=$(perl -pe 's/\e\[[0-9;?]*[a-zA-Z]//g; s/\e\].*?\a//g; s/[\x00-\x08\x0b\x0c\x0e-\x1f]//g' "$OUTPUT_FILE")

# Filter noise, get actual answer
RESULT=$(echo "$CLEAN" \
  | grep -v "^$" \
  | sed '/^[[:space:]]*$/d' \
  | tail -30 \
  | head -c 2000)

# Send result back via pane ID
if [ -n "$RESULT" ] && command -v herdr &>/dev/null; then
  # Replace newlines with pipe separator to avoid multi-line input issues
  RESULT_ONELINE=$(echo "$RESULT" | tr '\n' '|' | head -c 1500)
  herdr pane send-text "$RETURN_PANE" "[RETURN:agy] $RESULT_ONELINE" 2>/dev/null || true
  herdr pane send-keys "$RETURN_PANE" Enter 2>/dev/null || true
fi

# Report idle status
if command -v drovr &>/dev/null; then
  drovr agent report idle --message "Done" 2>/dev/null || true
fi
