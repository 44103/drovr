#!/usr/bin/env bash
# drovr: High-level agent collaboration patterns on herdr.
# Not a herdr wrapper — provides orchestrated behaviors built on herdr + hunk + AI CLIs.
# Usage: drovr <verb> [subcommand] [options]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

# shellcheck source=../lib/herdr-core.sh
source "${LIB_DIR}/herdr-core.sh"

DROVR_VERSION="0.2.0"

# --- Usage -------------------------------------------------------------------

usage() {
  cat <<EOF
drovr v${DROVR_VERSION} - agent collaboration patterns on herdr

Usage: drovr <verb> [subcommand] [options]

Verbs:
  diff start [target] [--staged] [-- <pathspec...>]
                                     Start live diff view (idempotent)
  diff stop                          Close the live diff pane
  diff status                        Check if live diff pane is running

  delegate "<[cli:]prompt>" [...]    Delegate task(s) to agent(s)
                                     1 arg = single, N args = parallel
  delegate clean                     Close all delegate panes

General:
  help                               Show this help
  version                            Show version

Supported CLIs for delegate (prefix with "cli:" or omit for default):
  kiro-cli     kiro-cli chat --no-interactive --trust-all-tools
  codex        codex exec
  agy          agy --dangerously-skip-permissions -p

Default CLI resolution: \$DROVR_CLI > \$HERDR_AGENT mapping > first in PATH

Environment:
  HERDR_SOCKET_PATH   Override socket path
  HERDR_PANE_ID       Override current pane ID
  HERDR_AGENT         Agent label (auto-set by herdr)
  DROVR_CLI           Default CLI for delegate (default: auto-detect)
EOF
}

# =============================================================================
# VERB: diff
# =============================================================================

DROVR_DIFF_LABEL="drovr:diff"

# Find the existing diff pane by agent name, label, or terminal title.
_diff_find_pane() {
  local response result
  response=$(herdr_rpc "pane.list" '{}')
  result=$(herdr_result "$response") || return 1

  python3 - "$result" "$DROVR_DIFF_LABEL" <<'PYTHON'
import json, sys
data = json.loads(sys.argv[1])
label = sys.argv[2]
panes = data.get("panes", [])
for p in panes:
    if p.get("name", "") == label:
        print(p["pane_id"])
        sys.exit(0)
    if p.get("label", "") == label:
        print(p["pane_id"])
        sys.exit(0)
    title = p.get("terminal_title_stripped", "") or p.get("terminal_title", "")
    if "hunk diff" in title and "--watch" in title:
        print(p["pane_id"])
        sys.exit(0)
print("")
PYTHON
}

cmd_diff_start() {
  local ratio=""
  local target=""
  local pathspec=()
  local staged=""
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --ratio) ratio="$2"; shift 2 ;;
      --staged|--cached) staged="--staged"; shift ;;
      --) shift; pathspec=("$@"); break ;;
      -*) extra_args+=("$1"); shift ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        else
          extra_args+=("$1")
        fi
        shift
        ;;
    esac
  done

  # Idempotent: skip if already running
  local existing_pane
  existing_pane=$(_diff_find_pane 2>/dev/null)
  if [[ -n "$existing_pane" ]]; then
    echo "diff already running in pane ${existing_pane}"
    return 0
  fi

  # Determine split direction from pane dimensions
  local layout_json
  layout_json=$(herdr pane layout --current 2>/dev/null) || {
    echo "Error: failed to get pane layout from herdr" >&2
    return 1
  }

  local direction
  direction=$(python3 - "$layout_json" <<'PYTHON'
import json, sys
data = json.loads(sys.argv[1])
layout = data.get("result", {}).get("layout", {})
area = layout.get("area", {})
width = area.get("width", 0)
height = area.get("height", 0)
if width > height * 2:
    print("right")
else:
    print("down")
PYTHON
  )

  # Build hunk command args
  local hunk_args=("hunk" "diff")
  if [[ -n "$staged" ]]; then
    hunk_args+=("--staged")
  fi
  hunk_args+=("--watch")
  if [[ -n "$target" ]]; then
    hunk_args+=("$target")
  fi
  if [[ ${#extra_args[@]} -gt 0 ]]; then
    hunk_args+=("${extra_args[@]}")
  fi
  if [[ ${#pathspec[@]} -gt 0 ]]; then
    hunk_args+=("--")
    hunk_args+=("${pathspec[@]}")
  fi

  # Atomic pane creation + command launch
  local start_args=("herdr" "agent" "start" "$DROVR_DIFF_LABEL" "--split" "$direction" "--no-focus")
  if [[ -n "$ratio" ]]; then
    start_args+=("--ratio" "$ratio")
  fi
  start_args+=("--" "${hunk_args[@]}")

  local output
  output=$("${start_args[@]}" 2>&1) || {
    echo "Error: failed to start diff pane: $output" >&2
    return 1
  }

  local new_pane_id
  new_pane_id=$(python3 - "$output" <<'PYTHON'
import json, sys
try:
    data = json.loads(sys.argv[1])
    result = data.get("result", data)
    agent = result.get("agent", {})
    print(agent.get("pane_id", ""))
except (json.JSONDecodeError, KeyError):
    print("")
PYTHON
  )

  echo "diff started in pane ${new_pane_id} (split: ${direction})"
  echo "  Command: ${hunk_args[*]}"
  echo "  Stop:    drovr diff stop"
}

cmd_diff_stop() {
  local pane_id
  pane_id=$(_diff_find_pane 2>/dev/null)

  if [[ -z "$pane_id" ]]; then
    echo "No diff pane running"
    return 0
  fi

  herdr pane close "$pane_id" >/dev/null 2>&1
  echo "diff pane ${pane_id} closed"
}

cmd_diff_status() {
  local pane_id
  pane_id=$(_diff_find_pane 2>/dev/null)

  if [[ -n "$pane_id" ]]; then
    echo "running (pane: ${pane_id})"
    return 0
  else
    echo "stopped"
    return 1
  fi
}

# =============================================================================
# VERB: delegate
# =============================================================================

DROVR_DELEGATE_PREFIX="drovr:delegate"

# Resolve the default CLI from the current agent environment.
# Priority: $DROVR_CLI > $HERDR_AGENT mapping > first available in PATH
_delegate_default_cli() {
  if [[ -n "${DROVR_CLI:-}" ]]; then
    echo "$DROVR_CLI"
    return 0
  fi

  # Map HERDR_AGENT to CLI name
  case "${HERDR_AGENT:-}" in
    kiro) echo "kiro-cli" ;;
    codex) echo "codex" ;;
    claude|agy) echo "agy" ;;
    *)
      # Fallback: first available
      if command -v kiro-cli >/dev/null 2>&1; then
        echo "kiro-cli"
      elif command -v codex >/dev/null 2>&1; then
        echo "codex"
      elif command -v agy >/dev/null 2>&1; then
        echo "agy"
      else
        echo ""
      fi
      ;;
  esac
}

# Parse "cli:prompt" or plain "prompt" (uses default CLI).
# Sets _PARSED_CLI and _PARSED_PROMPT.
_delegate_parse_arg() {
  local arg="$1"
  local default_cli="$2"

  # Check if arg contains "cli:" prefix (only known CLI names)
  case "$arg" in
    kiro-cli:*) _PARSED_CLI="kiro-cli"; _PARSED_PROMPT="${arg#kiro-cli:}" ;;
    codex:*)    _PARSED_CLI="codex";    _PARSED_PROMPT="${arg#codex:}" ;;
    agy:*)      _PARSED_CLI="agy";      _PARSED_PROMPT="${arg#agy:}" ;;
    *)          _PARSED_CLI="$default_cli"; _PARSED_PROMPT="$arg" ;;
  esac
}

cmd_delegate() {
  if [[ $# -eq 0 ]]; then
    cat >&2 <<'EOF'
Usage: drovr delegate "<[cli:]prompt>" ["<[cli:]prompt>" ...]
       drovr delegate clean

Examples:
  drovr delegate "Review this PR"
  drovr delegate "codex:Review this PR"
  drovr delegate "kiro-cli:Investigate auth" "codex:Check deps"
EOF
    return 1
  fi

  # Handle clean subcommand
  if [[ "$1" == "clean" ]]; then
    _delegate_clean_panes
    return $?
  fi

  local default_cli
  default_cli=$(_delegate_default_cli)
  if [[ -z "$default_cli" ]]; then
    echo "Error: no supported AI CLI found. Set DROVR_CLI or install kiro-cli/codex/agy." >&2
    return 1
  fi

  # Get caller pane for result delivery
  local return_pane
  return_pane=$(herdr_current_pane_id) || {
    echo "Error: cannot determine current pane ID" >&2
    return 1
  }

  if [[ $# -eq 1 ]]; then
    # Single delegation
    _delegate_single "$1" "$default_cli" "$return_pane"
  else
    # Multiple parallel delegations
    _delegate_parallel "$default_cli" "$return_pane" "$@"
  fi
}

_delegate_single() {
  local arg="$1"
  local default_cli="$2"
  local return_pane="$3"

  _delegate_parse_arg "$arg" "$default_cli"
  local cli="$_PARSED_CLI"
  local prompt="$_PARSED_PROMPT"

  local wrapper_path="${LIB_DIR}/delegate-${cli}.sh"
  if [[ ! -f "$wrapper_path" ]]; then
    echo "Error: no delegate wrapper for CLI '${cli}' (expected: ${wrapper_path})" >&2
    return 1
  fi

  # Determine split direction
  local layout_json
  layout_json=$(herdr pane layout --current 2>/dev/null) || {
    echo "Error: failed to get pane layout" >&2
    return 1
  }

  local direction
  direction=$(python3 - "$layout_json" <<'PYTHON'
import json, sys
data = json.loads(sys.argv[1])
layout = data.get("result", {}).get("layout", {})
area = layout.get("area", {})
width = area.get("width", 0)
height = area.get("height", 0)
if width > height * 2:
    print("right")
else:
    print("down")
PYTHON
  )

  local agent_name="${DROVR_DELEGATE_PREFIX}:${cli}:$$"

  local start_args=("herdr" "agent" "start" "$agent_name" "--split" "$direction" "--no-focus")
  start_args+=("--" "$wrapper_path" "$return_pane" "$prompt")

  local output
  output=$("${start_args[@]}" 2>&1) || {
    echo "Error: failed to start delegate: $output" >&2
    return 1
  }

  local new_pane_id
  new_pane_id=$(python3 - "$output" <<'PYTHON'
import json, sys
try:
    data = json.loads(sys.argv[1])
    result = data.get("result", data)
    agent = result.get("agent", {})
    print(agent.get("pane_id", ""))
except (json.JSONDecodeError, KeyError):
    print("")
PYTHON
  )

  echo "delegated to ${cli} in pane ${new_pane_id}"
  echo "  Prompt: ${prompt:0:60}..."
  echo "  Result: will arrive as [RETURN:${cli}] in your pane"
}

_delegate_parallel() {
  local default_cli="$1"
  local return_pane="$2"
  shift 2

  local num_agents=$#

  # Clean existing delegate panes first
  _delegate_clean_panes 2>/dev/null

  echo "Delegating to ${num_agents} agents..."

  # Split main pane: top 40% stays, bottom 60% for sub-agents
  local sub_area
  sub_area=$(herdr pane split "$return_pane" --direction down --ratio 0.4 --no-focus 2>/dev/null \
    | python3 -c "import json,sys; print(json.load(sys.stdin)['result']['pane']['pane_id'])" 2>/dev/null)

  if [[ -z "$sub_area" ]]; then
    echo "Error: failed to create sub-agent area" >&2
    return 1
  fi

  # Split sub area into N equal panes horizontally
  local panes=("$sub_area")

  for ((i=1; i<num_agents; i++)); do
    local remaining=$((num_agents - i))
    local ratio
    ratio=$(python3 -c "print(round(1.0 / ($remaining + 1), 2))")

    local last_pane="${panes[-1]}"
    local new_pane
    new_pane=$(herdr pane split "$last_pane" --direction right --ratio "$ratio" --no-focus 2>/dev/null \
      | python3 -c "import json,sys; print(json.load(sys.stdin)['result']['pane']['pane_id'])" 2>/dev/null)

    if [[ -z "$new_pane" ]]; then
      echo "Warning: failed to split pane (got ${#panes[@]}/${num_agents})" >&2
      break
    fi

    panes+=("$new_pane")
  done

  # Launch wrapper in each pane
  local idx=0
  for arg in "$@"; do
    if [[ $idx -ge ${#panes[@]} ]]; then
      echo "Warning: not enough panes for all agents" >&2
      break
    fi

    _delegate_parse_arg "$arg" "$default_cli"
    local cli="$_PARSED_CLI"
    local prompt="$_PARSED_PROMPT"
    local pane="${panes[$idx]}"
    local wrapper_path="${LIB_DIR}/delegate-${cli}.sh"

    if [[ ! -f "$wrapper_path" ]]; then
      echo "Warning: no wrapper for '${cli}', skipping" >&2
      ((idx++)) || true
      continue
    fi

    # Rename pane for identification
    herdr pane rename "$pane" "${DROVR_DELEGATE_PREFIX}" >/dev/null 2>&1

    # Wait for shell ready, then run
    herdr wait output "$pane" --match '❯' --source visible --timeout 10000 >/dev/null 2>&1 || sleep 2
    herdr pane run "$pane" "${wrapper_path} ${return_pane} '${prompt}' && exit" 2>/dev/null || true

    echo "  [${pane}] ${cli}: ${prompt:0:50}..."
    ((idx++)) || true
  done

  echo ""
  echo "All agents delegated. Results arrive as [RETURN:*] messages."
  echo "Cleanup: drovr delegate clean"
}

_delegate_clean_panes() {
  local response result
  response=$(herdr_rpc "pane.list" '{}')
  result=$(herdr_result "$response") || return 1

  local current_pane
  current_pane=$(herdr_current_pane_id 2>/dev/null) || true

  local panes_to_close
  panes_to_close=$(python3 - "$result" "$DROVR_DELEGATE_PREFIX" "${current_pane:-}" <<'PYTHON'
import json, sys
data = json.loads(sys.argv[1])
prefix = sys.argv[2]
current = sys.argv[3]
panes = data.get("panes", [])
to_close = []
for p in panes:
    pane_id = p.get("pane_id", "")
    if pane_id == current:
        continue
    name = p.get("name", "")
    label = p.get("label", "")
    if name.startswith(prefix) or label.startswith(prefix):
        to_close.append(pane_id)
for pid in to_close:
    print(pid)
PYTHON
  )

  if [[ -z "$panes_to_close" ]]; then
    echo "No delegate panes to close"
    return 0
  fi

  local count=0
  while IFS= read -r pane_id; do
    herdr pane close "$pane_id" >/dev/null 2>&1 && ((count++)) || true
  done <<< "$panes_to_close"

  echo "Closed ${count} delegate pane(s)"
}

# =============================================================================
# Main Dispatch
# =============================================================================

main() {
  if [[ $# -eq 0 ]]; then
    usage
    exit 0
  fi

  local verb="$1"
  shift

  case "$verb" in
    diff)
      if [[ $# -eq 0 ]]; then
        echo "Usage: drovr diff <start|stop|status>" >&2
        exit 1
      fi
      local subcmd="$1"
      shift
      case "$subcmd" in
        start) cmd_diff_start "$@" ;;
        stop) cmd_diff_stop "$@" ;;
        status) cmd_diff_status "$@" ;;
        *) echo "Unknown: drovr diff $subcmd" >&2; exit 1 ;;
      esac
      ;;
    delegate)
      if [[ $# -eq 0 ]]; then
        cmd_delegate
        exit 1
      fi
      cmd_delegate "$@"
      ;;
    help|--help|-h) usage ;;
    version|--version|-V) echo "drovr v${DROVR_VERSION}" ;;
    *) echo "Unknown verb: $verb" >&2; usage; exit 1 ;;
  esac
}

main "$@"
