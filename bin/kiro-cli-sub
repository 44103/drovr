#!/bin/bash
# kiro-cli wrapper for subagent spawning with auto-return
# Usage: kiro-cli-sub <return-pane-id> <prompt>
#   return-pane-id: herdr pane ID to send result back to (e.g. w3:pM)
#   prompt: the prompt to pass to kiro-cli

set -eu

RETURN_PANE="${1:?Usage: kiro-cli-sub <return-pane-id> <prompt>}"
shift
PROMPT="$*"

OUTPUT_FILE=$(mktemp /tmp/kiro-sub-XXXXXX.txt)
trap "rm -f $OUTPUT_FILE" EXIT

# Report working status
if command -v drovr &>/dev/null; then
  drovr agent report working --message "Running kiro-cli" 2>/dev/null || true
fi

# Run kiro-cli with tee so pane shows progress AND output is captured
kiro-cli chat --no-interactive --trust-all-tools "$PROMPT" 2>&1 | tee "$OUTPUT_FILE"

# Strip ANSI escape codes and zero-width characters
CLEAN=$(perl -pe 's/\e\[[0-9;?]*[a-zA-Z]//g; s/\e\].*?\a//g; s/[\x00-\x08\x0b\x0c\x0e-\x1f]//g; s/\x{200e}//g; s/\x{200b}//g' "$OUTPUT_FILE")

# Filter noise, get actual answer
RESULT=$(echo "$CLEAN" \
  | grep -v "^Searching\|^Fetching\|^ ✓\|^ - \|^Not all mcp\|^All tools\|^Agents can\|^Learn more\|^------\|▸ Time:" \
  | grep -v "^$" \
  | sed 's/^> //' \
  | sed '/^[[:space:]]*$/d' \
  | tail -30 \
  | head -c 1500)

# Send result back via pane ID (force single line)
if [ -n "$RESULT" ] && command -v herdr &>/dev/null; then
  RESULT_ONELINE=$(printf "%s" "$RESULT" | tr '\n\r' '||' | sed 's/||*/|/g' | head -c 1000)
  herdr pane send-text "$RETURN_PANE" "[RETURN] $RESULT_ONELINE" 2>/dev/null || true
  herdr pane send-keys "$RETURN_PANE" Enter 2>/dev/null || true
fi

# Report idle status
if command -v drovr &>/dev/null; then
  drovr agent report idle --message "Done" 2>/dev/null || true
fi
